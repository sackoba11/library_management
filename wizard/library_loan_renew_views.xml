<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ======================================================= -->
    <!-- VUE FORM DU WIZARD                                       -->
    <!-- ======================================================= -->
    <record id="library_loan_renew_view_form" model="ir.ui.view">
        <field name="name">library.loan.renew.form</field>
        <field name="model">library.loan.renew</field>
        <field name="arch" type="xml">
            <form string="Renouveler l'emprunt">

                <!-- En-tête informatif -->
                <div class="alert alert-info" role="alert">
                    <strong>Renouvellement d'emprunt</strong><br/>
                    Vous êtes sur le point de renouveler cet emprunt.
                    Maximum <strong>2 renouvellements</strong> autorisés
                    par emprunt.
                </div>

                <group string="Informations de l'emprunt">
                    <!-- IMPORTANT -->
                    <field name="loan_id" invisible="1"/>
                    <group>
                        <field name="book_id" readonly="1"/>
                        <field name="member_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="current_return_date" readonly="1"/>
                        <field name="renewal_count" readonly="1"/>
                    </group>
                </group>

                <group string="Paramètres du renouvellement">
                    <group>
                        <field name="duration_days"/>
                        <field name="new_return_date" readonly="1"/>
                    </group>
                </group>

                <group string="Raison">
                    <field name="reason"
                           nolabel="1"
                           placeholder="Saisissez la raison du renouvellement..."/>
                </group>

                <!-- Avertissement si max renouvellements atteint -->
                <div class="alert alert-warning"
                     role="alert"
                     invisible="renewal_count &lt; 2">
                    ⚠️ Attention : cet emprunt a déjà été renouvelé
                    <field name="renewal_count" readonly="1"/> fois.
                    C'est le maximum autorisé !
                </div>

                <!-- Boutons d'action du wizard -->
                <footer>
                    <button string="Confirmer le renouvellement"
                            name="action_renew"
                            type="object"
                            class="btn-primary"/>
                    <button string="Annuler"
                            name="action_cancel"
                            type="object"
                            class="btn-secondary"/>
                </footer>

            </form>
        </field>
    </record>

    <!-- ======================================================= -->
    <!-- ACTION DU WIZARD                                         -->
    <!-- ======================================================= -->
    <record id="library_loan_renew_action" model="ir.actions.act_window">
        <field name="name">Renouveler l'emprunt</field>
        <field name="res_model">library.loan.renew</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <!--
            target="new" → ouvre dans une fenêtre pop-up
            target="current" → remplace la vue actuelle
            target="inline" → intégré dans la page
        -->
        <field name="view_id" ref="library_loan_renew_view_form"/>
    </record>

</odoo>