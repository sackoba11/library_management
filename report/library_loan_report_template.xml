<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_library_loan_template">
        <!-- Enveloppe obligatoire Odoo 18 -->
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <t t-foreach="docs" t-as="doc">
                    <div class="page">

                        <!-- En-tête -->
                        <div class="row mb-4">
                            <div class="col-6">
                                <h2>FICHE D'EMPRUNT</h2>
                                <h4>
                                    <span t-field="doc.name"/>
                                </h4>
                            </div>
                        </div>

                        <hr/>

                        <!-- Statut -->
                        <div class="row mb-3">
                            <div class="col-12">
                                <span t-if="doc.state == 'draft'"
                                      class="badge bg-secondary">
                                    Brouillon
                                </span>
                                <span t-elif="doc.state == 'borrowed'"
                                      class="badge bg-primary">
                                    En cours
                                </span>
                                <span t-elif="doc.state == 'overdue'"
                                      class="badge bg-danger">
                                    EN RETARD
                                </span>
                                <span t-elif="doc.state == 'returned'"
                                      class="badge bg-success">
                                    Retourné
                                </span>
                                <span t-else=""
                                      class="badge bg-dark">
                                    Annulé
                                </span>
                            </div>
                        </div>

                        <!-- Infos principales -->
                        <div class="row mb-4">
                            <div class="col-6">
                                <table class="table table-sm table-bordered">
                                    <thead class="table-light">
                                        <tr>
                                            <th colspan="2">
                                                Membre
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td><strong>Nom</strong></td>
                                            <td>
                                                <span t-field="doc.member_id.name"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>N° Membre</strong></td>
                                            <td>
                                                <span t-field="doc.member_id.member_number"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Email</strong></td>
                                            <td>
                                                <span t-field="doc.member_id.email"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm table-bordered">
                                    <thead class="table-light">
                                        <tr>
                                            <th colspan="2">
                                                Livre
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td><strong>Titre</strong></td>
                                            <td>
                                                <span t-field="doc.book_id.title"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Auteur</strong></td>
                                            <td>
                                                <span t-field="doc.book_id.author_id.name"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>ISBN</strong></td>
                                            <td>
                                                <span t-field="doc.book_id.isbn"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Dates -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <table class="table table-bordered">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Date emprunt</th>
                                            <th>Retour prévu</th>
                                            <th>Durée (jours)</th>
                                            <th>Renouvellements</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>
                                                <span t-field="doc.loan_date"
                                                      t-options='{"format": "dd/MM/yyyy"}'/>
                                            </td>
                                            <td>
                                                <span t-field="doc.expected_return_date"
                                                      t-options='{"format": "dd/MM/yyyy"}'/>
                                            </td>
                                            <td>
                                                <span t-field="doc.loan_duration"/>
                                            </td>
                                            <td>
                                                <span t-field="doc.renewal_count"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Section retard (si applicable) -->
                        <t t-if="doc.delay_days > 0">
                            <div class="alert alert-danger">
                                <strong>Retard :</strong>
                                <span t-field="doc.delay_days"/> jour(s) —
                                Amende :
                                <span t-field="doc.fine_amount"/> FCFA
                            </div>
                        </t>

                        <!-- Notes -->
                        <t t-if="doc.notes">
                            <div class="row mt-3">
                                <div class="col-12">
                                    <strong>Notes :</strong>
                                    <p t-field="doc.notes"/>
                                </div>
                            </div>
                        </t>

                        <!-- Signatures -->
                        <div class="row mt-5">
                            <div class="col-6 text-center">
                                <div class="border-top pt-3">
                                    <p>Signature du membre</p>
                                    <br/><br/>
                                    <span t-field="doc.member_id.name"/>
                                </div>
                            </div>
                            <div class="col-6 text-center">
                                <div class="border-top pt-3">
                                    <p>Signature du bibliothécaire</p>
                                    <br/><br/>
                                    <strong>Le bibliothécaire</strong>
                                </div>
                            </div>
                        </div>

                        <!-- Saut de page sauf pour le dernier -->
                        <div t-if="not doc_last" class="page_break"/>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>