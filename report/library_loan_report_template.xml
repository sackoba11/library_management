<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ======================================================= -->
    <!-- TEMPLATE PRINCIPAL : FICHE D'EMPRUNT                    -->
    <!-- ======================================================= -->
    <template id="report_library_loan_template">
        <!--
            docs = liste des enregistrements à imprimer
            doc  = enregistrement courant dans la boucle
        -->
        <t t-foreach="docs" t-as="doc">

            <!-- o_report_layout_standard = mise en page Odoo standard -->
            <div class="page">

                <!-- =========================================== -->
                <!-- EN-TÊTE DU DOCUMENT                         -->
                <!-- =========================================== -->
                <div class="row mb-4">
                    <div class="col-6">
                        <!-- Logo de la société -->
                        <img t-if="company.logo"
                             t-att-src="image_data_uri(company.logo)"
                             style="max-height: 60px;"
                             alt="Logo"/>
                        <h3 t-field="company.name"/>
                    </div>
                    <div class="col-6 text-end">
                        <h2 class="text-primary">
                            FICHE D'EMPRUNT
                        </h2>
                        <h4>
                            <span class="badge bg-primary">
                                <t t-esc="doc.name"/>
                            </span>
                        </h4>
                    </div>
                </div>

                <hr/>

                <!-- =========================================== -->
                <!-- STATUT DE L'EMPRUNT                         -->
                <!-- =========================================== -->
                <div class="row mb-3">
                    <div class="col-12 text-center">
                        <!-- Badge coloré selon le statut -->
                        <span t-if="doc.state == 'draft'"
                              class="badge bg-secondary fs-6">
                            Brouillon
                        </span>
                        <span t-elif="doc.state == 'borrowed'"
                              class="badge bg-primary fs-6">
                            En cours
                        </span>
                        <span t-elif="doc.state == 'overdue'"
                              class="badge bg-danger fs-6">
                            ⚠️ EN RETARD
                        </span>
                        <span t-elif="doc.state == 'returned'"
                              class="badge bg-success fs-6">
                            ✅ Retourné
                        </span>
                        <span t-else=""
                              class="badge bg-dark fs-6">
                            Annulé
                        </span>
                    </div>
                </div>

                <!-- =========================================== -->
                <!-- INFORMATIONS PRINCIPALES                     -->
                <!-- =========================================== -->
                <div class="row mb-4">

                    <!-- Colonne gauche : Informations du membre -->
                    <div class="col-6">
                        <div class="card">
                            <div class="card-header bg-light">
                                <strong>👤 Informations du membre</strong>
                            </div>
                            <div class="card-body">
                                <table class="table table-sm">
                                    <tr>
                                        <td><strong>Nom</strong></td>
                                        <td>
                                            <span t-field="doc.member_id.name"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>N° Membre</strong></td>
                                        <td>
                                            <span t-field="doc.member_id.member_number"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>Email</strong></td>
                                        <td>
                                            <span t-field="doc.member_id.email"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>Téléphone</strong></td>
                                        <td>
                                            <span t-field="doc.member_id.mobile"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Colonne droite : Informations du livre -->
                    <div class="col-6">
                        <div class="card">
                            <div class="card-header bg-light">
                                <strong>📚 Informations du livre</strong>
                            </div>
                            <div class="card-body">
                                <table class="table table-sm">
                                    <tr>
                                        <td><strong>Titre</strong></td>
                                        <td>
                                            <span t-field="doc.book_id.title"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>Auteur</strong></td>
                                        <td>
                                            <span t-field="doc.book_id.author_id.name"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>ISBN</strong></td>
                                        <td>
                                            <span t-field="doc.book_id.isbn"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>Catégorie</strong></td>
                                        <td>
                                            <span t-field="doc.book_id.category_id.name"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- =========================================== -->
                <!-- DATES ET DURÉE                              -->
                <!-- =========================================== -->
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <strong>📅 Dates de l'emprunt</strong>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-3 text-center">
                                <div class="border rounded p-2">
                                    <small class="text-muted">
                                        Date d'emprunt
                                    </small>
                                    <div class="fw-bold">
                                        <span t-field="doc.loan_date"
                                              t-options='{"format": "dd/MM/yyyy"}'/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-3 text-center">
                                <div class="border rounded p-2">
                                    <small class="text-muted">
                                        Retour prévu
                                    </small>
                                    <div class="fw-bold">
                                        <span t-field="doc.expected_return_date"
                                              t-options='{"format": "dd/MM/yyyy"}'/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-3 text-center">
                                <div class="border rounded p-2">
                                    <small class="text-muted">
                                        Durée (jours)
                                    </small>
                                    <div class="fw-bold">
                                        <span t-field="doc.loan_duration"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-3 text-center">
                                <div class="border rounded p-2">
                                    <small class="text-muted">
                                        Renouvellements
                                    </small>
                                    <div class="fw-bold">
                                        <span t-field="doc.renewal_count"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- =========================================== -->
                <!-- SECTION RETARD (visible seulement si retard) -->
                <!-- =========================================== -->
                <t t-if="doc.is_overdue or doc.state == 'returned' and doc.delay_days > 0">
                    <div class="card mb-4 border-danger">
                        <div class="card-header bg-danger text-white">
                            <strong>⚠️ Informations de retard</strong>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-4 text-center">
                                    <div class="text-danger">
                                        <h4>
                                            <span t-field="doc.delay_days"/>
                                        </h4>
                                        <small>Jours de retard</small>
                                    </div>
                                </div>
                                <div class="col-4 text-center">
                                    <div class="text-danger">
                                        <h4>
                                            <span t-field="doc.fine_amount"/>
                                            FCFA
                                        </h4>
                                        <small>Montant de l'amende</small>
                                    </div>
                                </div>
                                <div class="col-4 text-center">
                                    <div>
                                        <h4>
                                            <span t-field="doc.return_date"
                                                  t-options='{"format": "dd/MM/yyyy"}'/>
                                        </h4>
                                        <small>Date de retour effective</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>

                <!-- =========================================== -->
                <!-- NOTES                                        -->
                <!-- =========================================== -->
                <t t-if="doc.notes">
                    <div class="card mb-4">
                        <div class="card-header bg-light">
                            <strong>📝 Notes</strong>
                        </div>
                        <div class="card-body">
                            <p t-field="doc.notes"/>
                        </div>
                    </div>
                </t>

                <!-- =========================================== -->
                <!-- SIGNATURES                                   -->
                <!-- =========================================== -->
                <div class="row mt-5">
                    <div class="col-6 text-center">
                        <div class="border-top pt-3">
                            <p>Signature du membre</p>
                            <br/><br/>
                            <strong>
                                <span t-field="doc.member_id.name"/>
                            </strong>
                        </div>
                    </div>
                    <div class="col-6 text-center">
                        <div class="border-top pt-3">
                            <p>Signature du bibliothécaire</p>
                            <br/><br/>
                            <strong>Le bibliothécaire</strong>
                        </div>
                    </div>
                </div>

                <!-- Saut de page entre les documents -->
                <div t-if="not doc_last"
                     class="page_break"/>

            </div>
        </t>
    </template>

    <!-- ======================================================= -->
    <!-- TEMPLATE : RAPPORT DES RETARDS                          -->
    <!-- ======================================================= -->
    <template id="report_library_overdue_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">

                    <!-- En-tête -->
                    <div class="text-center mb-4">
                        <h2 class="text-danger">
                            RAPPORT DES EMPRUNTS EN RETARD
                        </h2>
                        <p class="text-muted">
                            Généré le :
                            <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y à %H:%M')"/>
                        </p>
                    </div>

                    <!-- Statistiques globales -->
                    <div class="row mb-4">
                        <div class="col-4 text-center">
                            <div class="card bg-danger text-white p-3">
                                <h3>
                                    <t t-esc="len(docs)"/>
                                </h3>
                                <p>Emprunt(s) en retard</p>
                            </div>
                        </div>
                        <div class="col-4 text-center">
                            <div class="card bg-warning p-3">
                                <h3>
                                    <t t-esc="sum(doc.fine_amount for doc in docs)"/>
                                    FCFA
                                </h3>
                                <p>Total des amendes</p>
                            </div>
                        </div>
                        <div class="col-4 text-center">
                            <div class="card bg-info text-white p-3">
                                <h3>
                                    <t t-esc="max((doc.delay_days for doc in docs), default=0)"/>
                                </h3>
                                <p>Retard maximum (jours)</p>
                            </div>
                        </div>
                    </div>

                    <!-- Tableau des emprunts en retard -->
                    <table class="table table-striped table-bordered">
                        <thead class="table-danger">
                            <tr>
                                <th>Référence</th>
                                <th>Membre</th>
                                <th>Livre</th>
                                <th>Date emprunt</th>
                                <th>Retour prévu</th>
                                <th>Jours retard</th>
                                <th>Amende (FCFA)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="doc">
                                <tr>
                                    <td>
                                        <strong>
                                            <t t-esc="doc.name"/>
                                        </strong>
                                    </td>
                                    <td>
                                        <t t-esc="doc.member_id.name"/>
                                    </td>
                                    <td>
                                        <t t-esc="doc.book_id.title"/>
                                    </td>
                                    <td>
                                        <span t-field="doc.loan_date"
                                              t-options='{"format": "dd/MM/yyyy"}'/>
                                    </td>
                                    <td>
                                        <span t-field="doc.expected_return_date"
                                              t-options='{"format": "dd/MM/yyyy"}'/>
                                    </td>
                                    <td class="text-danger fw-bold">
                                        <t t-esc="doc.delay_days"/>
                                    </td>
                                    <td class="text-danger fw-bold">
                                        <t t-esc="doc.fine_amount"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                        <!-- Ligne totaux -->
                        <tfoot class="table-secondary">
                            <tr>
                                <td colspan="5">
                                    <strong>TOTAL</strong>
                                </td>
                                <td class="fw-bold">
                                    <t t-esc="sum(doc.delay_days for doc in docs)"/>
                                    jours
                                </td>
                                <td class="fw-bold">
                                    <t t-esc="sum(doc.fine_amount for doc in docs)"/>
                                    FCFA
                                </td>
                            </tr>
                        </tfoot>
                    </table>

                </div>
            </t>
        </t>
    </template>

</odoo>