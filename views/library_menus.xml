<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ======================================================= -->
    <!-- NIVEAU 1 : MENU PRINCIPAL                                 -->
    <!-- ======================================================= -->

    <menuitem
        id="library_menu_root"
        name="Bibliothèque"
        sequence="10"
        web_icon="library_management,static/description/icon.png"/>
        <!--
            id       : identifiant unique du menu
            name     : texte affiché
            sequence : ordre d'affichage (plus petit = plus à gauche)
            web_icon : icône affichée dans la barre des apps
        -->

    <!-- ======================================================= -->
    <!-- NIVEAU 2 : MENUS PRINCIPAUX                              -->
    <!-- ======================================================= -->

    <!-- Menu Tableau de bord -->
    <menuitem
        id="library_menu_dashboard"
        name="Tableau de bord"
        parent="library_menu_root"
        action="library_loan_action"
        sequence="1"/>

    <!-- Menu Emprunts -->
    <menuitem
        id="library_menu_loans"
        name="Emprunts"
        parent="library_menu_root"
        action="library_loan_action"
        sequence="2"/>

    <!-- Menu Livres -->
    <menuitem
        id="library_menu_books"
        name="Livres"
        parent="library_menu_root"
        action="library_book_action"
        sequence="3"/>

    <!-- Menu Membres -->
    <menuitem
        id="library_menu_members"
        name="Membres"
        parent="library_menu_root"
        action="library_member_action"
        sequence="4"
        groups="library_management.group_library_librarian"
        />

    <!-- Menu Configuration (conteneur sans action) -->
    <menuitem
        id="library_menu_config"
        name="Configuration"
        parent="library_menu_root"
        sequence="10"
        groups="library_management.group_library_librarian"/>
        <!-- Pas d'action → c'est un conteneur pour les sous-menus -->

    <!-- ======================================================= -->
    <!-- NIVEAU 3 : SOUS-MENUS DE CONFIGURATION                   -->
    <!-- ======================================================= -->

    <menuitem
        id="library_menu_categories"
        name="Catégories"
        parent="library_menu_config"
        action="library_category_action"
        sequence="1"/>

    <menuitem
        id="library_menu_authors"
        name="Auteurs"
        parent="library_menu_config"
        action="library_author_action"
        sequence="2"/>

</odoo>